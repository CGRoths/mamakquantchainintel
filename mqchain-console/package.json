{
  "name": "mqchain-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "kv:legacy-preview": "tsx --env-file=.env.local scripts/compile-kv.ts",
    "kv:request-full": "tsx --env-file=.env.local tools/kv-compiler/request-full.ts",
    "kv:compile": "tsx --env-file=.env.local tools/kv-compiler/cli.ts",
    "kv:verify": "tsx --env-file=.env.local tools/kv-compiler/cli.ts",
    "kv:register": "tsx --env-file=.env.local tools/kv-compiler/cli.ts",
    "kv:parity": "tsx --env-file=.env.local tools/kv-compiler/cli.ts",
    "u1:reports": "tsx scripts/generate-u1-reports.ts",
    "u1:drift": "tsx --env-file=.env.local scripts/generate-u1-drift-report.ts",
    "mqchain:dictionary-bundle": "tsx --env-file=.env.local scripts/generate-dictionary-bundle.ts",
    "test": "vitest run",
    "origin:start": "tsx --env-file=.env.origin.local origin/server.ts",
    "origin:dev": "tsx --env-file=.env.origin.local origin/server.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bloom-filters": "3.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^4.24.14",
    "papaparse": "^5.5.4",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rocksdb": "^5.2.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
